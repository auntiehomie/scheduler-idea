# Oura Ring personal access token
# Get yours at: https://cloud.ouraring.com/personal-access-tokens
OURA_ACCESS_TOKEN=your_oura_access_token_here

# LLM API keys (optional — at least one enables AI-powered dynamic schedules)
# Claude Haiku 4.5 via Anthropic (budget option: ~$1/$5 per million tokens)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek V4 Flash (ultra-budget: ~$0.14/$0.28 per million tokens)
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Menstrual cycle tracking (optional)
# Date of last period start in YYYY-MM-DD format
CYCLE_START_DATE=

# Average cycle length in days (default: 28)
CYCLE_LENGTH=28

# Time slot blocking (optional)
# Comma-separated 24h times when you're unavailable for scheduling
# Example: "09:00,13:30" blocks 9:00 AM and 1:30 PM slots
BLOCKED_SLOTS=

# Port for local development (default: 3000)
PORT=3000
